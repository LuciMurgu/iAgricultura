# ============================================================
# Farm Copilot - Local development environment
# ============================================================
# Copy this file to .env and adjust values as needed.
# For production env templates, see infrastructure/env/.

# ----- Database (local Postgres via docker-compose.dev.yml) -----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farm_copilot

# ----- API server -----
ENV=development
SESSION_SECRET_KEY=dev-only-not-secret-change-in-prod
FRONTEND_URL=http://localhost:3000

# ----- ANAF integration (optional in dev) -----
ANAF_ENCRYPTION_KEY=
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=http://localhost:8000/anaf/callback
ANAF_TEST_MODE=true
ANAF_SYNC_ENABLED=false
ANAF_SYNC_INTERVAL_SECONDS=14400

# ----- Frontend -----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRICT_API=false
