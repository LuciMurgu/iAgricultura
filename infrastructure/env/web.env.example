# ============================================================
# Farm Copilot Web - Production environment template (Vercel)
# ============================================================
# Set these in the Vercel project's Environment Variables panel.
# Production scope only. Preview and development can differ.

# Backend API origin (must be HTTPS in production).
NEXT_PUBLIC_API_URL=https://api.iagricultura.ro

# Disable the mock-data fallback in hooks.
# When true, API errors surface as errors instead of silently using fixtures.
NEXT_PUBLIC_STRICT_API=true
