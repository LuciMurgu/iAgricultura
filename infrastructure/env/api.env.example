# ============================================================
# Farm Copilot API - Production environment template
# ============================================================
# Copy to .env.production at the repo root and fill in real values.
# Never commit the filled-in version.

# ----- Database (Supabase transaction pooler) -----
# Format:
#   postgresql+asyncpg://postgres.<project>:<password>@aws-eu-west-1.pooler.supabase.com:6543/postgres?ssl=require
DATABASE_URL=

# ----- Session (FastAPI / Starlette) -----
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=

# ----- Frontend origin (CORS allowlist) -----
# Exact origin: scheme + host, no trailing slash.
FRONTEND_URL=https://iagricultura.ro

# ----- Session cookie -----
# Parent domain so the SPA (iagricultura.ro) can send the session cookie to
# the API (api.iagricultura.ro). Leave empty for single-host / localhost.
SESSION_COOKIE_DOMAIN=.iagricultura.ro

# ----- ANAF integration -----
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ANAF_ENCRYPTION_KEY=
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=https://api.iagricultura.ro/anaf/callback
ANAF_TEST_MODE=false
ANAF_SYNC_ENABLED=true
ANAF_SYNC_INTERVAL_SECONDS=14400

# ----- App -----
ENV=production

# ----- Demo account (showcase build) -----
# Seeded on first startup so the login walkthrough works immediately.
# Set DEMO_SEED_ENABLED=false for a real-data launch.
DEMO_SEED_ENABLED=true
DEMO_USER_EMAIL=demo@iagricultura.ro
DEMO_USER_PASSWORD=demo1234
DEMO_USER_NAME=Cont Demo
DEMO_FARM_NAME=Ferma Demo
