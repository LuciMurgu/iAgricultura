DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farm_copilot
PORT=8000
ENV=development
SESSION_SECRET_KEY=dev-secret-change-in-production
ANAF_ENCRYPTION_KEY=
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=
ANAF_REDIRECT_URI=http://localhost:8000/anaf/callback
ANAF_TEST_MODE=true
# ANAF Auto-Sync Scheduler
ANAF_SYNC_ENABLED=true
ANAF_SYNC_INTERVAL_SECONDS=14400
ANAF_SYNC_INITIAL_DELAY_SECONDS=60

# ----- Email (Resend) + self-service signup approval -----
# Leave RESEND_API_KEY empty in dev: signup still works and the approval link
# is logged instead of emailed.
RESEND_API_KEY=
EMAIL_FROM=Farm Copilot <onboarding@resend.dev>
ADMIN_EMAIL=
API_PUBLIC_URL=http://localhost:8000
