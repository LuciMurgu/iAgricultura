# ── Database ──────────────────────────────────────
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── ANAF OAuth ────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ANAF_ENCRYPTION_KEY=GENERATE_AND_PASTE_HERE
ANAF_CLIENT_ID=your_anaf_client_id
ANAF_CLIENT_SECRET=your_anaf_client_secret
ANAF_REDIRECT_URI=https://yourdomain.com/anaf/callback
ANAF_TEST_MODE=false

# ── Auto-Sync ────────────────────────────────────
ANAF_SYNC_ENABLED=true
ANAF_SYNC_INTERVAL_SECONDS=14400

# ── Application ──────────────────────────────────
ENV=production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=GENERATE_AND_PASTE_HERE

# ── CORS ─────────────────────────────────────────
# Production frontend URL — required for cross-origin API calls
FRONTEND_URL=https://farm-copilot.yourdomain.com

# ── Database (standalone Docker, not docker-compose) ─
# docker-compose sets this automatically via service name
# DATABASE_URL=postgresql+asyncpg://farm_copilot:PASSWORD@db-host:5432/farm_copilot
